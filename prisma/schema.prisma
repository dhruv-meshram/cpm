generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DependencyType {
  FS
  SS
  FF
  SF
}

enum LagUnit {
  days
  hours
  weeks
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkItemState {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  DELAYED
  COMPLETED
}

enum ProjectHealth {
  HEALTHY
  WARNING
  AT_RISK
}

model Workspace {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members     WorkspaceMember[]
  projects    Project[]
  labels      Label[]
}

model User {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  avatar       String?
  passwordHash String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspaceMemberships WorkspaceMember[]
  projectMemberships    ProjectMember[]
  ownedProjects         Project[]
  comments              Comment[]
  activityLogs          ActivityLog[]
  workLogs              WorkLog[]
  taskAssignees         TaskAssignee[]
  votes                 Vote[]
  taskSubscribers       TaskSubscriber[]
  notifications         Notification[]
  announcements         Announcement[]
  announcementReads    AnnouncementRead[]
  taskApprovals         TaskApproval[]
  decisions             Decision[]         @relation("DecisionMaker")
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}

model Project {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  identifier  String
  description String?
  startDate   DateTime?
  targetDate  DateTime?
  status      ProjectStatus @default(DRAFT)
  health      ProjectHealth @default(HEALTHY)
  ownerId     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  members     ProjectMember[]
  dependencies Dependency[]
  cycles      Cycle[]
  modules     Module[]
  milestones  Milestone[]
  releases    Release[]
  layouts     GraphLayout[]
  snapshots   CPMSnapshot[]
  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  departments Department[]
  tags        Tag[]
  announcements Announcement[]
  decisions     Decision[]
  notifications Notification[]
  customRoles   ProjectCustomRole[]

  @@unique([workspaceId, identifier])
  @@index([workspaceId])
}

model ProjectMember {
  projectId    String
  userId       String
  role         String      @default("Member") // Can be Member, Department Head, Project Manager, Captain, Admin or custom role name
  departmentId String?
  customRoleId String?
  createdAt    DateTime    @default(now())
  lastActiveAt DateTime?   @default(now())

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  customRole   ProjectCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@id([projectId, userId])
  @@index([userId])
  @@index([departmentId])
  @@index([customRoleId])
  @@map("project_members")
}

model ProjectCustomRole {
  id               String   @id @default(cuid())
  projectId        String
  name             String
  description      String?

  // Permissions (Slabs of Control)
  approveTasks     Boolean  @default(false)
  changeTaskStatus Boolean  @default(false)
  addTasks         Boolean  @default(false)
  modifyTasks      String   @default("ALL") // "ALL", "ASSIGNED", "NONE"
  addDepartments   Boolean  @default(false)
  manageTags       Boolean  @default(false)
  makeAnnouncements Boolean @default(false)
  manageTeam       Boolean  @default(false)
  manageRoles      Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectMembers   ProjectMember[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_custom_roles")
}

model Task {
  id              String         @id
  projectId       String
  title           String
  description     String?
  duration        Int
  estimatedDays   Int?
  startDate       DateTime?
  endDate         DateTime?
  state           WorkItemState   @default(BACKLOG)
  priority        Int            @default(0)
  parentTaskId    String?
  isDraft         Boolean        @default(true)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask      Task?          @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks      Task[]         @relation("TaskHierarchy")
  taskLabels      TaskLabel[]
  outgoingDependencies Dependency[] @relation("DependencySuccessor")
  incomingDependencies Dependency[] @relation("DependencyPredecessor")
  assignees       TaskAssignee[]
  comments        Comment[]
  workLogs        WorkLog[]
  taskCustomValues TaskCustomValue[]
  subscriptions   TaskSubscriber[]
  votes           Vote[]
  nodePosition    NodePosition?
  departments     Department[]   @relation("TaskDepartments")
  taskTags        TaskTag[]
  approvals       TaskApproval[]
  decisions       Decision[]     @relation("TaskDecisions")
  notifications   Notification[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([deletedAt])
}

model Dependency {
  id                String         @id @default(cuid())
  projectId         String
  predecessorTaskId  String
  successorTaskId    String
  dependencyType    DependencyType
  lag               Decimal        @default(0) @db.Decimal(12, 4)
  lagUnit           LagUnit        @default(days)
  strength          Decimal        @default(1.0) @db.Decimal(4, 2)
  createdAt         DateTime       @default(now())

  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecessorTask   Task           @relation("DependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask     Task           @relation("DependencySuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)

  @@unique([predecessorTaskId, successorTaskId, dependencyType])
  @@index([projectId])
  @@index([predecessorTaskId])
  @@index([successorTaskId])
}

model TaskAssignee {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model Label {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model Tag {
  id        String    @id @default(cuid())
  projectId String
  name      String
  color     String?   @default("#7f8c8d")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model ActivityLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  userId        String?
  timestamp     DateTime @default(now())
  workspaceName String?
  userRole      String?
  userName      String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
}

model WorkLog {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  duration    Decimal  @db.Decimal(12, 4)
  description String?
  date        DateTime

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Cycle {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  ownerId     String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Module {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  targetDate  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Release {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  version     String
  releaseDate DateTime?
  status      String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
}

model GraphLayout {
  id           String   @id @default(cuid())
  projectId    String
  layoutEngine String
  version      String
  generatedAt  DateTime @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodePositions NodePosition[]

  @@index([projectId])
}

model NodePosition {
  id        String  @id @default(cuid())
  layoutId  String  @unique
  taskId    String  @unique
  x         Float
  y         Float
  width     Float?
  height    Float?

  layout GraphLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model CPMSnapshot {
  id              String   @id @default(cuid())
  projectId       String
  version         String
  calculationTime DateTime @default(now())
  projectDuration Decimal  @db.Decimal(12, 4)
  criticalPath    Json
  payload         Json

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, version])
  @@index([calculationTime])
}

model TaskSubscriber {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model Vote {
  id      String @id @default(cuid())
  taskId  String
  userId  String
  type    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskCustomValue {
  id        String @id @default(cuid())
  taskId    String
  key       String
  value     Json?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Department {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  color       String   // hex or Tailwind color (e.g., #000000, red-500)
  archived    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]   @relation("TaskDepartments")
  projectMembers ProjectMember[]

  @@unique([projectId, name])
  @@index([projectId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // MEMBER, DEPARTMENT_HEAD, PROJECT_MANAGER, CAPTAIN, ADMIN
  description String?

  @@map("roles")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  projectId   String?
  taskId      String?
  type        String           // TASK_ASSIGNED, TASK_REMOVED, etc.
  title       String
  content     String
  isRead      Boolean          @default(false)
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model Announcement {
  id        String   @id @default(cuid())
  projectId String
  creatorId String
  title     String
  content   String   @db.Text
  priority  String   @default("Normal") // Normal, Important, Critical
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  reads   AnnouncementRead[]

  @@index([projectId])
  @@index([createdAt])
  @@map("announcements")
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model TaskApproval {
  id         String   @id @default(cuid())
  taskId     String
  reviewerId String
  decision   String   // SUBMITTED, APPROVED, REJECTED
  comment    String?  @db.Text
  timestamp  DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_approvals")
}

model Decision {
  id              String   @id @default(cuid())
  projectId       String
  title           String
  description     String   @db.Text
  reasoning       String   @db.Text
  alternatives    String   @db.Text
  decisionMakerId String
  date            DateTime @default(now())
  status          String   @default("Proposed") // Proposed, Approved, Archived
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decisionMaker User    @relation("DecisionMaker", fields: [decisionMakerId], references: [id], onDelete: Cascade)
  tasks         Task[]  @relation("TaskDecisions")

  @@index([projectId])
  @@map("decisions")
}
