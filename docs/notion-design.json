{
  "color": {
    "Surface Base": {
      "$type": "color",
      "$value": "#f6f5f4",
      "$description": "Primary page and section background; warm off-white used across content areas"
    },
    "Hero Deep Navy": {
      "$type": "color",
      "$value": "#02093a",
      "$description": "Campaign hero section background; dark navy used for the 'Meet the night shift' hero"
    },
    "Primary Text": {
      "$type": "color",
      "$value": "#000000",
      "$description": "Body text, headings, nav links, and borders across the page"
    },
    "White Surface": {
      "$type": "color",
      "$value": "#ffffff",
      "$description": "Card surfaces, dropdown panels, and CTA button text on dark backgrounds"
    },
    "Action Blue": {
      "$type": "color",
      "$value": "#097fe8",
      "$description": "Primary CTA button fill ('Get Notion free'), interactive highlights"
    },
    "Link Blue": {
      "$type": "color",
      "$value": "#0075de",
      "$description": "Text links, focus states, accent borders"
    },
    "Muted Gray": {
      "$type": "color",
      "$value": "#a39e98",
      "$description": "Secondary/muted text, icon fills, placeholder text"
    },
    "Medium Gray": {
      "$type": "color",
      "$value": "#615d59",
      "$description": "Tertiary text, icon button states"
    },
    "Border Subtle": {
      "$type": "color",
      "$value": "#000000",
