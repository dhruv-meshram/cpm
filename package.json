{
  "name": "cpm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npx prisma generate && npx prisma migrate deploy && cmake -S . -B build && cmake --build build --target cpm_cli && npm run build --prefix apps/web",
    "start": "node apps/web/server.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:ebaja": "tsx scripts/seed-ebaja-project.ts",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:test:validation": "tsx database/tests/validation.test.ts",
    "db:test:schema": "tsx database/tests/schema.test.ts",
    "db:test:crud": "tsx database/tests/crud.integration.test.ts",
    "db:test:constraints": "tsx database/tests/constraints.test.ts",
    "db:test:transaction": "tsx database/tests/transaction.test.ts",
    "db:test:benchmark": "tsx database/tests/benchmark.test.ts",
    "db:bench:run": "tsx scripts/db_benchmark_runner.ts",
    "db:bench:aggregate": "tsx scripts/aggregate_reports.ts",
    "db:bench:matrix": "tsx scripts/db_benchmark_matrix.ts default",
    "db:bench:matrix:full": "tsx scripts/db_benchmark_matrix.ts full",
    "db:bench:visualize": "tsx scripts/db_benchmark_visualize.ts",
    "db:bench:matrix:report": "npm run db:bench:matrix && npm run db:bench:visualize",
    "db:bench:all": "tsx scripts/generate_master_benchmark_report.ts",
    "db:test:volume:small": "tsx scripts/db_volume_benchmark.ts small",
    "db:test:volume:medium": "tsx scripts/db_volume_benchmark.ts medium",
    "db:test:volume:large": "tsx scripts/db_volume_benchmark.ts large"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prisma": "^6.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
